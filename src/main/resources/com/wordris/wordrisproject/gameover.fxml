<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.wordris.wordrisproject.GameOverController"
           stylesheets="@styles.css"
           prefWidth="500" prefHeight="600">

    <VBox alignment="CENTER" spacing="0" styleClass="menu-root">

        <VBox alignment="CENTER" spacing="8" styleClass="title-block">
            <Label text="BETTER LUCK NEXT TIME" styleClass="subtitle-label"/>
        </VBox>

        <HBox alignment="CENTER" spacing="4" styleClass="tile-row">
            <Label text="G" styleClass="deco-tile"/>
            <Label text="A" styleClass="deco-tile"/>
            <Label text="M" styleClass="deco-tile"/>
            <Label text="E" styleClass="deco-tile"/>
            <Label text="O" styleClass="deco-tile"/>
            <Label text="V" styleClass="deco-tile"/>
            <Label text="E" styleClass="deco-tile"/>
            <Label text="R" styleClass="deco-tile"/>
        </HBox>

        <VBox alignment="CENTER" spacing="8" prefWidth="220">
            <Label text="FINAL SCORE" styleClass="card-label"/>
            <Label fx:id="finalScoreLabel" text="0" styleClass="card-value"/>
        </VBox>

        <VBox alignment="CENTER" spacing="14" styleClass="button-block">
            <Button text="RESTART"
                    fx:id="restartButton"
                    styleClass="btn-primary"
                    onAction="#onRestart"
                    maxWidth="220"/>
            <Button text="MAIN MENU"
                    fx:id="menuButton"
                    styleClass="btn-secondary"
                    onAction="#onMainMenu"
                    maxWidth="220"/>
        </VBox>

    </VBox>
</StackPane>
